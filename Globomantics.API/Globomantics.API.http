@Globomantics.API_HostAddress = http://localhost:5038

### API verification without sending tags
POST {{Globomantics.API_HostAddress}}/products
Content-Type: application/json

{
    "name": "USB Cable",
    "price": 9.99,
    "categoryId": "a1b2c3d4-0001-0001-0001-000000000001"
}

### API verification sending tags
POST {{Globomantics.API_HostAddress}}/products
Content-Type: application/json

{
    "name": "Mechanical Keyboard",
    "price": 149.99,
    "categoryId": "a1b2c3d4-0001-0001-0001-000000000001",
    "tags": ["keyboard", "mechanical", "gaming"]
}


### Partial update — only change the price (PATCH)
PATCH {{Globomantics.API_HostAddress}}/products/b2c3d4e5-0002-0002-0002-000000000001
Content-Type: application/merge-patch+json

{
    "price": 89.99
}

### Partial update — clear description (set to null)
PATCH {{Globomantics.API_HostAddress}}/products/b2c3d4e5-0002-0002-0002-000000000001
Content-Type: application/merge-patch+json

{
    "description": null
}

### API V1 status check
GET {{Globomantics.API_HostAddress}}/products?api-version=v1

### Testing product updates with Pricing
GET {{Globomantics.API_HostAddress}}/products/b2c3d4e5-0002-0002-0002-000000000001


### Testing product creation with Pricing
POST {{Globomantics.API_HostAddress}}/products
Content-Type: application/json

{
    "name": "Bluetooth Speaker",
    "price": 49.99,
    "categoryId": "a1b2c3d4-0001-0001-0001-000000000001",
    "tags": ["audio", "bluetooth", "portable"]
}

### Get reviews for a product
GET {{Globomantics.API_HostAddress}}/products/b2c3d4e5-0002-0002-0002-000000000001/reviews
Accept: application/json

### Get a specific review
GET {{Globomantics.API_HostAddress}}/products/b2c3d4e5-0002-0002-0002-000000000001/reviews/c3d4e5f6-0003-0003-0003-000000000001
Accept: application/json

### Create a new review
POST {{Globomantics.API_HostAddress}}/products/b2c3d4e5-0002-0002-0002-000000000001/reviews
Content-Type: application/json

{
    "author": "Diana",
    "rating": 4,
    "comment": "Comfortable and great battery life."
}

### Get reviews for non-existent product (expect 404)
GET {{Globomantics.API_HostAddress}}/products/00000000-0000-0000-0000-000000000000/reviews
Accept: application/json
